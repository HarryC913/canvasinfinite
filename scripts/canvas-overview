#!/usr/bin/env python3
"""
canvas-overview — toggle a full-display overview for the canvasinfinite plugin.

Zooms ALL monitors OUT together (via Hyprland's monitor scale — crisp compositor
downscale, not a render hack) so the whole canvas reads as one continuous space
spanning every display, then toggles back. Pairs with the canvasinfinite plugin's
canvas mode but works on any floating layout.

Spanning, not duplicating: a lower scale grows each monitor's logical region, so at
native positions adjacent monitors would OVERLAP and show the same area twice. We
use ONE uniform scale for every monitor and reposition them so they stay contiguous
(no overlap), anchored at the bottom-right-most monitor so every monitor only ever
grows left/up — which keeps each monitor's own windows inside its expanded region.

Why a script: monitor scale only persists through Hyprland's keyword/config path,
which a render-plugin can't reach in-process. Driving `hyprctl keyword monitor` from
a small helper is the idiomatic, reliable way to do a view/monitor operation.

Bind it to a key, e.g.:
    bind = SUPER, Tab, exec, ~/.config/hypr/canvas-overview
"""

import json
import os
import subprocess
import sys

STATE = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "canvasinfinite-overview.state")
ACTIVE = os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "canvasinfinite-active")
MARGIN = 0.92          # leave a small border around the fitted windows
MIN_SCALE = 0.1        # never shrink past this
STEP_FRACTION = 0.5    # always zoom out to AT MOST this fraction of native scale, so a
                       # press is always visibly a step back even when windows fill the
                       # screen; spread-out windows zoom out further to fit.


def hjson(*args):
    out = subprocess.run(["hyprctl", "-j", *args], capture_output=True, text=True).stdout
    return json.loads(out)


def set_monitor(line):
    subprocess.run(["hyprctl", "keyword", "monitor", line], capture_output=True, text=True)


def monitor_line(m, scale, x=None, y=None):
    # resolution is the MODE size; rotation is applied separately via transform.
    x = m["x"] if x is None else int(round(x))
    y = m["y"] if y is None else int(round(y))
    line = f'{m["name"]},{m["width"]}x{m["height"]}@{m["refreshRate"]:.5f},{x}x{y},{scale:g}'
    if m.get("transform", 0):
        line += f',transform,{m["transform"]}'
    return line


def logical_dims(m):
    # logical orientation: 90/270 rotations swap width/height
    if m.get("transform", 0) in (1, 3, 5, 7):
        return float(m["height"]), float(m["width"])
    return float(m["width"]), float(m["height"])


def main():
    # only ENTER overview when canvas mode is on (plugin writes the ACTIVE marker). Leaving
    # overview is always allowed, so you can never get stuck zoomed if canvas turned off.
    if not os.path.exists(STATE) and not os.path.exists(ACTIVE):
        return

    # already in overview -> restore the saved monitor lines and exit
    if os.path.exists(STATE):
        for line in open(STATE):
            line = line.strip()
            if line:
                set_monitor(line)
        os.remove(STATE)
        return

    monitors = hjson("monitors")
    clients = hjson("clients")
    if not monitors:
        return

    # Pick ONE uniform scale for every monitor: the most-zoomed-out of each monitor's
    # target, so the whole canvas fits and the displays tile consistently. Each monitor's
    # target = fit-to-its-content, but never less zoom than the step-back floor.
    targets = []
    for m in monitors:
        wsid = m["activeWorkspace"]["id"]
        wins = [c for c in clients
                if c.get("mapped") and not c.get("hidden", False) and c["workspace"]["id"] == wsid]
        step = m["scale"] * STEP_FRACTION
        if wins:
            minx = min(c["at"][0] for c in wins)
            miny = min(c["at"][1] for c in wins)
            maxx = max(c["at"][0] + c["size"][0] for c in wins)
            maxy = max(c["at"][1] + c["size"][1] for c in wins)
            bw = max(1.0, maxx - minx)
            bh = max(1.0, maxy - miny)
            phys_w, phys_h = logical_dims(m)
            fit = min(phys_w / bw, phys_h / bh) * MARGIN  # fit-to-content
            target = min(fit, step)                       # zoom further if spread, else step back
        else:
            target = step
        targets.append(min(target, m["scale"]))           # never magnify past native

    scale = max(MIN_SCALE, min(targets))

    # Anchor at the bottom-right-most monitor and scale every monitor's position toward it
    # by 1/scale. Natively-contiguous monitors stay contiguous (the gaps grow with the
    # regions), and because every monitor only moves left/up, each one's expanded region
    # still covers its original area -> its windows stay on screen, no overlap/duplication.
    ax = max(m["x"] for m in monitors)
    ay = max(m["y"] for m in monitors)

    saved = [monitor_line(m, m["scale"]) for m in monitors]  # native lines, for restore
    for m in monitors:
        nx = ax + (m["x"] - ax) / scale
        ny = ay + (m["y"] - ay) / scale
        set_monitor(monitor_line(m, round(scale, 4), nx, ny))

    with open(STATE, "w") as f:
        f.write("\n".join(saved) + "\n")


if __name__ == "__main__":
    main()
